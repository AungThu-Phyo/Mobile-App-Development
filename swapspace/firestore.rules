rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function _userAllowedFields() {
      return ['uid', 'name', 'email', 'avatarUrl', 'rating', 'totalSessions', 'createdAt', 'lastSeen', 'isActive', 'isProfileComplete', 'faculty', 'bio', 'activityPreferences', 'interactionPreference'];
    }

    function _publicProfileAllowedFields() {
      return ['uid', 'name', 'avatarUrl', 'rating', 'totalSessions', 'faculty', 'bio', 'activityPreferences', 'interactionPreference', 'updatedAt'];
    }

    function _sessionAllowedFields() {
      return ['sessionId', 'creatorUid', 'creatorName', 'partnerUid', 'activityType', 'title', 'description', 'location', 'date', 'durationMinutes', 'interactionPreference', 'status', 'faculty', 'isActive', 'maxParticipants', 'participantUids', 'minRating', 'createdAt', 'updatedAt'];
    }

    function _joinRequestAllowedFields() {
      return ['requestId', 'sessionId', 'requesterUid', 'creatorUid', 'requestType', 'message', 'status', 'createdAt', 'updatedAt'];
    }

    function _notificationAllowedFields() {
      return ['notificationId', 'recipientUid', 'senderUid', 'senderName', 'sessionId', 'sessionTitle', 'type', 'message', 'isRead', 'createdAt'];
    }

    function _allowedNotificationTypes() {
      return ['join_request', 'request_accepted', 'request_rejected', 'session_updated', 'participant_left'];
    }

    function _feedbackAllowedFields() {
      return ['feedbackId', 'sessionId', 'reviewerUid', 'revieweeUid', 'rating', 'comment', 'didShowUp', 'createdAt'];
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(_userAllowedFields())
        && request.resource.data.keys().hasAll(_userAllowedFields())
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.avatarUrl is string
        && request.resource.data.rating is number
        && request.resource.data.totalSessions is int
        && request.resource.data.createdAt is timestamp
        && request.resource.data.lastSeen is timestamp
        && request.resource.data.isActive is bool
        && request.resource.data.isProfileComplete is bool
        && request.resource.data.faculty is string
        && request.resource.data.bio is string
        && request.resource.data.activityPreferences is list
        && request.resource.data.interactionPreference is string;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(_userAllowedFields())
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.name is string
        && request.resource.data.avatarUrl is string
        && request.resource.data.rating is number
        && request.resource.data.totalSessions is int
        && request.resource.data.lastSeen is timestamp
        && request.resource.data.isActive is bool
        && request.resource.data.isProfileComplete is bool
        && request.resource.data.faculty is string
        && request.resource.data.bio is string
        && request.resource.data.activityPreferences is list
        && request.resource.data.interactionPreference is string;

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /publicProfiles/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(_publicProfileAllowedFields())
        && request.resource.data.keys().hasAll(_publicProfileAllowedFields())
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.avatarUrl is string
        && request.resource.data.rating is number
        && request.resource.data.totalSessions is int
        && request.resource.data.faculty is string
        && request.resource.data.bio is string
        && request.resource.data.activityPreferences is list
        && request.resource.data.interactionPreference is string
        && request.resource.data.updatedAt is timestamp;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(_publicProfileAllowedFields())
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.name is string
        && request.resource.data.avatarUrl is string
        && request.resource.data.rating is number
        && request.resource.data.totalSessions is int
        && request.resource.data.faculty is string
        && request.resource.data.bio is string
        && request.resource.data.activityPreferences is list
        && request.resource.data.interactionPreference is string
        && request.resource.data.updatedAt is timestamp;

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /sessions/{sessionId} {
      allow read: if request.auth != null
        && (
          (resource.data.status == 'open' && resource.data.isActive == true)
          || resource.data.creatorUid == request.auth.uid
          || resource.data.partnerUid == request.auth.uid
          || request.auth.uid in resource.data.participantUids
        );

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(_sessionAllowedFields())
        && request.resource.data.keys().hasAll(_sessionAllowedFields())
        && request.resource.data.sessionId == sessionId
        && request.resource.data.creatorUid == request.auth.uid
        && request.resource.data.creatorName is string
        && request.resource.data.partnerUid is string
        && request.resource.data.activityType is string
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.location is string
        && request.resource.data.date is timestamp
        && request.resource.data.durationMinutes is int
        && request.resource.data.interactionPreference is string
        && request.resource.data.status == 'open'
        && request.resource.data.faculty is string
        && request.resource.data.isActive is bool
        && request.resource.data.maxParticipants is int
        && request.resource.data.participantUids is list
        && request.resource.data.minRating is number
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if request.auth != null
        && request.resource.data.keys().hasOnly(_sessionAllowedFields())
        && request.resource.data.sessionId == resource.data.sessionId
        && request.resource.data.creatorUid == resource.data.creatorUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && (
          (
            resource.data.creatorUid == request.auth.uid
            && (!('creatorName' in request.resource.data) || request.resource.data.creatorName is string)
            && (!('partnerUid' in request.resource.data) || request.resource.data.partnerUid is string)
            && (!('activityType' in request.resource.data) || request.resource.data.activityType is string)
            && (!('title' in request.resource.data) || request.resource.data.title is string)
            && (!('description' in request.resource.data) || request.resource.data.description is string)
            && (!('location' in request.resource.data) || request.resource.data.location is string)
            && (!('date' in request.resource.data) || request.resource.data.date is timestamp)
            && (!('durationMinutes' in request.resource.data) || request.resource.data.durationMinutes is int)
            && (!('interactionPreference' in request.resource.data) || request.resource.data.interactionPreference is string)
            && (!('status' in request.resource.data) || request.resource.data.status in ['open', 'matched', 'completed', 'cancelled'])
            && (!('faculty' in request.resource.data) || request.resource.data.faculty is string)
            && (!('isActive' in request.resource.data) || request.resource.data.isActive is bool)
            && (!('maxParticipants' in request.resource.data) || request.resource.data.maxParticipants is int)
            && (!('participantUids' in request.resource.data) || request.resource.data.participantUids is list)
            && (!('minRating' in request.resource.data) || request.resource.data.minRating is number)
          )
          ||
          (
            request.auth.uid in resource.data.participantUids
            && !(request.auth.uid in request.resource.data.participantUids)
            && request.resource.data.participantUids is list
            && request.resource.data.participantUids.size() + 1 == resource.data.participantUids.size()
            && request.resource.data.status == 'open'
            && request.resource.data.partnerUid == ''
            && request.resource.data.creatorName == resource.data.creatorName
            && request.resource.data.activityType == resource.data.activityType
            && request.resource.data.title == resource.data.title
            && request.resource.data.description == resource.data.description
            && request.resource.data.location == resource.data.location
            && request.resource.data.date == resource.data.date
            && request.resource.data.durationMinutes == resource.data.durationMinutes
            && request.resource.data.interactionPreference == resource.data.interactionPreference
            && request.resource.data.faculty == resource.data.faculty
            && request.resource.data.isActive == resource.data.isActive
            && request.resource.data.maxParticipants == resource.data.maxParticipants
            && request.resource.data.minRating == resource.data.minRating
          )
        );

      allow delete: if request.auth != null && resource.data.creatorUid == request.auth.uid;
    }

    match /joinRequests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.requesterUid || request.auth.uid == resource.data.creatorUid);

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(_joinRequestAllowedFields())
        && request.resource.data.keys().hasAll(_joinRequestAllowedFields())
        && request.resource.data.requestId == requestId
        && request.resource.data.requesterUid == request.auth.uid
        && request.resource.data.sessionId is string
        && request.resource.data.creatorUid is string
        && request.resource.data.requestType is string
        && (!('message' in request.resource.data) || request.resource.data.message is string)
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if request.auth != null
        && (request.auth.uid == resource.data.requesterUid || request.auth.uid == resource.data.creatorUid)
        && request.resource.data.keys().hasOnly(_joinRequestAllowedFields())
        && request.resource.data.requestId == resource.data.requestId
        && request.resource.data.sessionId == resource.data.sessionId
        && request.resource.data.requesterUid == resource.data.requesterUid
        && request.resource.data.creatorUid == resource.data.creatorUid
        && request.resource.data.createdAt == resource.data.createdAt
        && (!('message' in request.resource.data) || request.resource.data.message is string)
        && request.resource.data.updatedAt is timestamp
        && ((request.auth.uid == resource.data.requesterUid && request.resource.data.status == 'cancelled')
            || (request.auth.uid == resource.data.creatorUid && request.resource.data.status in ['accepted', 'rejected', 'pending']));

      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.requesterUid || request.auth.uid == resource.data.creatorUid);
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.recipientUid || request.auth.uid == resource.data.senderUid);

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(_notificationAllowedFields())
        && request.resource.data.keys().hasAll(_notificationAllowedFields())
        && request.resource.data.notificationId == notificationId
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.senderName is string
        && request.resource.data.sessionId is string
        && request.resource.data.sessionTitle is string
        && request.resource.data.type is string
        && request.resource.data.type in _allowedNotificationTypes()
        && request.resource.data.message is string
        && request.resource.data.isRead is bool
        && request.resource.data.createdAt is timestamp;

      allow update: if request.auth != null
        && request.auth.uid == resource.data.recipientUid
        && request.resource.data.keys().hasOnly(_notificationAllowedFields())
        && request.resource.data.keys().hasAll(_notificationAllowedFields())
        && request.resource.data.notificationId == resource.data.notificationId
        && request.resource.data.recipientUid == resource.data.recipientUid
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.senderName == resource.data.senderName
        && request.resource.data.sessionId == resource.data.sessionId
        && request.resource.data.sessionTitle == resource.data.sessionTitle
        && request.resource.data.type == resource.data.type
        && request.resource.data.message == resource.data.message
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.isRead is bool;

      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.recipientUid || request.auth.uid == resource.data.senderUid);
    }

    match /feedback/{feedbackId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.reviewerUid || request.auth.uid == resource.data.revieweeUid);

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(_feedbackAllowedFields())
        && request.resource.data.keys().hasAll(_feedbackAllowedFields())
        && request.resource.data.feedbackId == feedbackId
        && request.resource.data.reviewerUid == request.auth.uid
        && request.resource.data.sessionId is string
        && request.resource.data.revieweeUid is string
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.didShowUp is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.revieweeUid != request.resource.data.reviewerUid
        && get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.status == 'completed'
        && (
          request.auth.uid == get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.creatorUid
          || request.auth.uid in get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.participantUids
        )
        && (
          request.resource.data.revieweeUid == get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.creatorUid
          || request.resource.data.revieweeUid in get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.participantUids
        );

      allow update: if false;

      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.reviewerUid || request.auth.uid == resource.data.revieweeUid);
    }
  }
}
